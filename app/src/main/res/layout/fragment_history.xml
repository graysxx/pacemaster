<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbars="none">

    <LinearLayout
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="110dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- JUDUL -->
        <TextView
            android:text="@string/title_history"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- TAB SELECTION -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/card_glass"
            android:padding="5dp"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/btn_lime"
                android:text="@string/tab_this_week"
                android:textColor="@color/bg"
                android:textStyle="bold"
                android:gravity="center"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/tab_this_month"
                android:textColor="@color/muted_fg"
                android:gravity="center"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/tab_all"
                android:textColor="@color/muted_fg"
                android:gravity="center"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>
        </LinearLayout>

        <!-- RINGKASAN STATS (3 Kartu) -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:background="@drawable/card_glass"
                android:gravity="center"
                android:layout_marginEnd="10dp">
                <TextView
                    android:text="@string/placeholder_total_distance"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/label_total_distance"
                    android:textColor="@color/muted_fg"
                    android:textSize="11sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:background="@drawable/card_glass"
                android:gravity="center"
                android:layout_marginEnd="10dp">
                <TextView
                    android:text="@string/placeholder_total_time"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/label_total_time"
                    android:textColor="@color/muted_fg"
                    android:textSize="11sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:background="@drawable/card_glass"
                android:gravity="center">
                <TextView
                    android:text="@string/placeholder_pace"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/label_avg_pace_small"
                    android:textColor="@color/muted_fg"
                    android:textSize="11sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- DAFTAR AKTIVITAS -->

        <!-- Item 1: Morning Run -->
        <LinearLayout
            android:id="@+id/itemRun1"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <FrameLayout
                    android:id="@+id/iconRun1"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/icon_circle_bg"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_run_path"
                        android:contentDescription="@string/desc_run_icon"
                        app:tint="@color/lime"/>
                </FrameLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/iconRun1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="@string/label_morning_run"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="@string/label_today_time"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <FrameLayout
                        android:id="@+id/btnShareItem1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_circle_bg"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_share"
                            app:tint="@color/lime"
                            android:contentDescription="Share activity"/>
                    </FrameLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_play"
                        android:alpha="0.4"
                        android:contentDescription="@string/desc_play_icon"
                        app:tint="@color/text_primary"/>
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:baselineAligned="false"
                android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_dist_5_2_km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_distance_km" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_duration" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_duration" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_pace_5_14" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_pace" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Item 2: Long Run -->
        <LinearLayout
            android:id="@+id/itemRun2"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <FrameLayout
                    android:id="@+id/iconRun2"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/icon_circle_bg"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_run_path"
                        android:contentDescription="@string/desc_run_icon"
                        app:tint="@color/lime"/>
                </FrameLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/iconRun2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="@string/label_long_run"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="@string/label_yesterday_time"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <FrameLayout
                        android:id="@+id/btnShareItem2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_circle_bg"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_share"
                            app:tint="@color/lime"
                            android:contentDescription="Share activity"/>
                    </FrameLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_play"
                        android:alpha="0.4"
                        android:contentDescription="@string/desc_play_icon"
                        app:tint="@color/text_primary"/>
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:baselineAligned="false"
                android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_dist_7_8_km_plain" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_distance_km" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_duration_42_33" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_duration" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_pace_5_27_plain" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_pace" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Item 3: Evening Run -->
        <LinearLayout
            android:id="@+id/itemRun3"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <FrameLayout
                    android:id="@+id/iconRun3"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/icon_circle_bg"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_run_path"
                        android:contentDescription="@string/desc_run_icon"
                        app:tint="@color/lime"/>
                </FrameLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/iconRun3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="@string/label_evening_run"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="@string/label_2_days_ago_time"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <FrameLayout
                        android:id="@+id/btnShareItem3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_circle_bg"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_share"
                            app:tint="@color/lime"
                            android:contentDescription="Share activity"/>
                    </FrameLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_play"
                        android:alpha="0.4"
                        android:contentDescription="@string/desc_play_icon"
                        app:tint="@color/text_primary"/>
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:baselineAligned="false"
                android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_dist_4_1_km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_distance_km" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_duration_22_07" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_duration" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/placeholder_pace_5_23" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="@string/label_pace" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>