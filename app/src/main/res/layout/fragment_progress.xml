<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbars="none">

    <LinearLayout
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="110dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:text="@string/title_progress"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_leaderboard"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_trophy"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@string/desc_trophy_icon"
                        app:tint="@color/lime"/>
                    <TextView
                        android:text="@string/label_leaderboard"
                        android:textColor="@color/lime"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- CARD TARGET BULANAN -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">
                <TextView
                    android:text="@string/label_monthly_target"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/placeholder_monthly_target_val"
                    android:textColor="@color/lime"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Progress bar bulanan -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/progress_track"
                android:layout_marginBottom="10dp">
                <View
                    android:id="@+id/progressMonthly"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/progress_fill"/>
            </FrameLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/placeholder_monthly_achieved_val"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/placeholder_percentage"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD JARAK MINGGUAN (Bar Chart) -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <TextView
                    android:text="@string/label_weekly_distance"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/placeholder_month_year"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Custom Bar Chart View -->
            <com.example.pace.views.BarChartView
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="160dp"/>
        </LinearLayout>

        <!-- CARD TREN PACE (Line Chart) -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:text="@string/label_pace_trend"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="@string/desc_trend_icon"
                        app:tint="@color/lime"/>
                    <TextView
                        android:text="@string/label_improving"
                        android:textColor="@color/lime"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Custom Line Chart View -->
            <com.example.pace.views.LineChartView
                android:id="@+id/lineChart"
                android:layout_width="match_parent"
                android:layout_height="140dp"/>
        </LinearLayout>

        <!-- CARD KONSISTENSI HARIAN (Calendar dots) -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:text="@string/label_daily_consistency"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@string/placeholder_full_month_year"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Calendar grid View -->
            <com.example.pace.views.CalendarDotsView
                android:id="@+id/calendarDots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>