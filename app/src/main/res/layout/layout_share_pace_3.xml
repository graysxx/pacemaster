<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="1080px"
    android:layout_height="1920px"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@color/bg"
    android:padding="0dp">
    <ImageView
        android:id="@+id/ivShareBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"/>


    <View
        android:layout_width="match_parent"
        android:layout_height="800px"
        android:background="@color/lime"
        android:layout_alignParentTop="true"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PACE"
        android:textColor="@color/bg"
        android:textSize="200px"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="200px"
        android:letterSpacing="-0.05"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="600px"
        android:padding="80px">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="60px">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JARAK TOTAL"
                android:textColor="@color/muted_fg"
                android:textSize="32px"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvShareJarak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.20 km"
                android:textColor="@color/text_primary"
                android:textSize="140px"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2px"
                android:background="@color/divider"
                android:layout_marginVertical="40px"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURASI"
                        android:textColor="@color/muted_fg"
                        android:textSize="28px" />
                    <TextView
                        android:id="@+id/tvShareWaktu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="27:14"
                        android:textColor="@color/text_primary"
                        android:textSize="56px"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RITME"
                        android:textColor="@color/muted_fg"
                        android:textSize="28px" />
                    <TextView
                        android:id="@+id/tvSharePace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5:14"
                        android:textColor="@color/text_primary"
                        android:textSize="56px"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_run_path"
            android:tint="@color/lime"
            android:layout_marginTop="80px"
            android:padding="40px"/>

    </LinearLayout>

</RelativeLayout>
