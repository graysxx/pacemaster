<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- MAP / PATH SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#0F0F12">

                <!-- Placeholder for Path Drawing -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="40dp"
                    android:src="@drawable/ic_run_path"
                    android:tint="#2A2A2F"/>

                <!-- Mock Path Line (Simulated) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/ic_run_path"
                    android:alpha="0.8"
                    android:layout_margin="50dp"
                    android:tint="@color/lime"/>

                <!-- Top Buttons -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:layout_marginTop="30dp">

                    <FrameLayout
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_circle_bg"
                        android:backgroundTint="#1A1A1D"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_play"
                            android:rotation="180"
                            android:tint="@color/text_primary"/>
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/icon_circle_bg"
                        android:backgroundTint="@color/lime">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_progress"
                            android:tint="@color/bg"/>
                    </FrameLayout>
                </RelativeLayout>

                <!-- Markers Legend -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Start"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:layout_marginEnd="15dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Finish"
                        android:textColor="@color/lime"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHeaderJarak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="20dp"
                    android:text="5.20 km"
                    android:textColor="@color/lime"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

            </RelativeLayout>

            <!-- ACTIVITY INFO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/icon_circle_bg"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_stat_bolt"
                            app:tint="@color/lime"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Morning Run"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hari ini · 06:30 · 📍 Jakarta"
                    android:textColor="@color/muted_fg"
                    android:textSize="14sp"/>

                <!-- Main Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/tvDetailJarak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5.20" android:textColor="@color/lime" android:textSize="24sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="JARAK (KM)" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/tvDetailPace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5:14" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PACE RATA2" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/tvDetailWaktu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="27:14" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DURASI" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- TABS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/card_glass"
                android:padding="5dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnTabRingkasan"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:background="@drawable/btn_lime">
                    <TextView
                        android:id="@+id/tvTabRingkasan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Ringkasan"
                        android:textStyle="bold"
                        android:textColor="@color/bg"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnTabSplit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/tvTabSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Split"
                        android:textColor="@color/muted_fg" />
                </FrameLayout>
            </LinearLayout>

            <!-- TAB CONTENT: RINGKASAN -->
            <LinearLayout
                android:id="@+id/layoutRingkasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:visibility="visible">

                <!-- 4 Mini Cards -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="4"
                    android:rowCount="1">

                    <!-- Kalori -->
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <TextView android:id="@+id/tvCalories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="338" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kalori" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>
                    <!-- Langkah -->
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <TextView android:id="@+id/tvSteps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6,933" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Langkah" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>
                    <!-- Kenaikan -->
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <TextView android:id="@+id/tvDetailElev" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 m" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kenaikan" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>
                    <!-- Elev Maks -->
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvMaxElev" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18 m" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Elev Maks" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                    </LinearLayout>
                </GridLayout>

                <!-- Pace Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pace" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="min/km" android:textColor="#40C8F43A" android:background="@drawable/card_glass" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp"/>
                    </RelativeLayout>
                    <com.example.pace.views.LineChartView
                        android:id="@+id/chartPace"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:chartColor="@color/lime"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5:14 /km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pace Rata2" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5:14 /km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pace Total" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5:03 /km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Split Cepat" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Kadens Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kadens" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="langkah/mnt" android:textColor="#409C27B0" android:background="@drawable/card_glass" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp"/>
                    </RelativeLayout>
                    <com.example.pace.views.LineChartView
                        android:id="@+id/chartKadens"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:chartColor="@color/purple"/>
                </LinearLayout>

                <!-- Elevasi Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Elevasi" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="meter" android:textColor="#40FF9800" android:background="@drawable/card_glass" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp"/>
                    </RelativeLayout>
                    <com.example.pace.views.LineChartView
                        android:id="@+id/chartElevasi"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:chartColor="@color/orange"/>
                </LinearLayout>
            </LinearLayout>

            <!-- TAB CONTENT: SPLIT -->
            <LinearLayout
                android:id="@+id/layoutSplit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/splitContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <!-- Table Header -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="KM" android:textColor="@color/muted_fg" android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_weight="1.5" android:layout_height="wrap_content" android:text="PACE" android:textColor="@color/muted_fg" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_weight="1.5" android:layout_height="wrap_content" android:text="ELEV" android:textColor="@color/muted_fg" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:text="BAR" android:textColor="@color/muted_fg" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM BUTTON -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="20dp"
        android:background="@drawable/bottom_nav_gradient">

        <LinearLayout
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/btn_lime"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/btnShareIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_share"
                app:tint="@color/bg"
                android:layout_marginEnd="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bagikan Aktivitas"
                android:textColor="@color/bg"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
