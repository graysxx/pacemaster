<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1080px"
    android:layout_height="1920px"
    android:background="@color/bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/ivShareBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Overlay Gradasi agar teks tetap terbaca jika ada foto -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_nav_gradient" />

    <!-- Watermark PACE Vertikal -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="100px"
        android:layout_marginEnd="-80px"
        android:alpha="0.08"
        android:rotation="90"
        android:text="PACE"
        android:textColor="@color/text_primary"
        android:textSize="450px"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="80px">

        <TextView
            android:id="@+id/tvShareJarak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="5.20"
            android:textColor="@color/lime"
            android:textSize="340px"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40px"
            android:letterSpacing="0.2"
            android:text="KILOMETERS COMPLETED"
            android:textColor="@color/text_primary"
            android:textSize="42px"
            android:textStyle="bold" />

        <View
            android:layout_width="120px"
            android:layout_height="6px"
            android:layout_marginVertical="60px"
            android:background="@color/lime" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:text="TIME"
                    android:textColor="@color/text_primary"
                    android:textSize="30px"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvShareWaktu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="27:14"
                    android:textColor="@color/text_primary"
                    android:textSize="64px"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:text="AVG PACE"
                    android:textColor="@color/text_primary"
                    android:textSize="30px"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvSharePace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5:14"
                    android:textColor="@color/text_primary"
                    android:textSize="64px"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:text="ELEV"
                    android:textColor="@color/text_primary"
                    android:textSize="30px"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvShareElev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15m"
                    android:textColor="@color/text_primary"
                    android:textSize="64px"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivSharePath"
        android:layout_width="600px"
        android:layout_height="600px"
        android:layout_centerVertical="true"
        android:layout_marginStart="-150px"
        android:alpha="0.15"
        android:src="@drawable/ic_run_path"
        app:tint="@color/lime" />

</RelativeLayout>