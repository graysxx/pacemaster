<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Logo box -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/logo_bg"
            android:layout_gravity="center"
            android:elevation="12dp">

            <!-- Ikon lari (tanda V terbalik) -->
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/ic_run_path"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PACE"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RUN SMARTER"
            android:textColor="@color/muted_fg"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:layout_marginTop="6dp"/>

        <!-- Loading dots -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center">

            <View android:id="@+id/dot1"
                android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/dot_shape"
                android:layout_marginEnd="6dp"/>
            <View android:id="@+id/dot2"
                android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/dot_shape"
                android:layout_marginEnd="6dp"/>
            <View android:id="@+id/dot3"
                android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/dot_shape"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>