<?xml version="1.0" encoding="utf-8"?>
<!--
    Struktur baru:
    1) Header (back + judul) - terpisah dari area preview, jadi tombol back
       TIDAK PERNAH menimpa kartu preview lagi.
    2) Tab pemilih mode (Polos / PACE Theme) sebagai dua kartu besar, sesuai referensi desain.
    3) previewContainer - kartu preview, konten selalu di-scale & center (lihat scaleToFitPreview di kode).
    4) Navigator tema (panah kiri/kanan + dot indicator) - hanya tampil saat mode PACE Theme,
       menggantikan daftar thumbnail supaya lebih modern & tidak berdempetan.
    5) bottomControls - panel kontrol dengan tinggi tetap. Area yang bisa panjang (background,
       editor elemen) di-scroll SENDIRI, sementara tombol "Simpan & Bagikan" dipasang FIXED
       di luar ScrollView sehingga selalu langsung terlihat, tidak pernah "kedorong" ke bawah.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- 1) Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/icon_circle_bg"
            android:backgroundTint="@color/lime">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:rotation="180"
                app:tint="@color/bg" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Bagikan Aktivitas"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2) Mode selector: dua kartu besar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/tabDefault"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_tab_selected">

            <TextView
                android:id="@+id/tvTabPolosLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PACE"
                android:textColor="@color/lime"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTabPolosValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.2"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTabPolosSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5:14 /km · 27:14"
                android:textColor="@color/muted_fg"
                android:textSize="9sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTabPolosMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Polos"
                android:textColor="@color/lime"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabPaceTheme"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_glass">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_run_path"
                app:tint="@color/muted_fg"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvTabThemeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PACE Theme"
                android:textColor="@color/muted_fg"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 3) Preview Container -->
    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@color/bg">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="32dp"
            android:layout_marginVertical="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#000000"
            app:strokeWidth="0dp"
            app:cardPreventCornerOverlap="false">

            <FrameLayout
                android:id="@+id/shareFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">
                <!-- Content (Polos/Theme) akan dimasukkan di sini lewat kode -->
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- 4) Theme navigator: panah + dot, hanya tampil di mode PACE Theme -->
    <LinearLayout
        android:id="@+id/paceStyleSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/btnThemePrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_arrow_bg">
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:rotation="180"
                app:tint="@color/lime" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="16dp">
            <!-- Dot indicators ditambahkan lewat kode -->
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnThemeNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_arrow_bg">
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                app:tint="@color/lime" />
        </FrameLayout>
    </LinearLayout>

    <!-- 5) Panel Kontrol -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass"
        android:elevation="12dp"
        android:paddingTop="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="220dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/panelContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Ganti Background: pill full-width, modern, tidak berdempetan -->
                <LinearLayout
                    android:id="@+id/btnAddImage"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_glass_pill"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_play"
                        android:rotation="-90"
                        android:layout_marginEnd="10dp"
                        app:tint="@color/lime"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganti Background"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Default/Polos Controls: editor elemen HANYA muncul di mode Polos -->
                <LinearLayout
                    android:id="@+id/defaultControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/elementEditor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_glass"
                        android:backgroundTint="#0DFFFFFF"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/selectedElementName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nama Elemen"
                            android:textColor="@color/lime"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"/>

                        <!-- Size Slider -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="Size"
                                android:textColor="@color/muted_fg"
                                android:textSize="12sp"/>
                            <SeekBar android:id="@+id/sbSize"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="50"
                                android:progressDrawable="@drawable/seekbar_track"
                                android:thumb="@drawable/seekbar_thumb"
                                android:splitTrack="false"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"/>
                        </LinearLayout>

                        <!-- Rotation Slider -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="Rotate"
                                android:textColor="@color/muted_fg"
                                android:textSize="12sp"/>
                            <SeekBar android:id="@+id/sbRotation"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:max="360"
                                android:progress="180"
                                android:progressDrawable="@drawable/seekbar_track"
                                android:thumb="@drawable/seekbar_thumb"
                                android:splitTrack="false"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Tombol Simpan: FIXED di luar ScrollView, selalu langsung terlihat -->
        <TextView
            android:id="@+id/btnSaveShare"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/btn_lime"
            android:elevation="4dp"
            android:gravity="center"
            android:text="Simpan &amp; Bagikan"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textSize="15sp"
            android:letterSpacing="0.02" />

    </LinearLayout>

</LinearLayout>
