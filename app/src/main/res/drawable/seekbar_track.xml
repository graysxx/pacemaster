<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background" android:gravity="center_vertical" android:height="6dp">
        <shape>
            <corners android:radius="3dp" />
            <solid android:color="#33FFFFFF" />
        </shape>
    </item>
    <item android:id="@android:id/progress" android:gravity="center_vertical" android:height="6dp">
        <clip>
            <shape>
                <corners android:radius="3dp" />
                <solid android:color="@color/lime" />
            </shape>
        </clip>
    </item>
</layer-list>
