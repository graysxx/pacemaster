<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="NavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="NavLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#76767F</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Wrapper yang menampung ikon+label satu item nav, tempat highlight aktif ditempelkan -->
    <style name="NavItemBadge">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/nav_item_selected_bg</item>
    </style>

    <style name="DayLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#76767F</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
    </style>


</resources>